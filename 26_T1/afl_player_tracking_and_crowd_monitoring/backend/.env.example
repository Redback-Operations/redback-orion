# Service URLs
PLAYER_SERVICE_URL=http://localhost:8001
CROWD_SERVICE_URL=http://localhost:8002
BACKEND_PORT=8000
UPLOAD_DIR=uploads

# Set to true during development (no player/crowd services needed)
# Set to false to call real player/crowd services
USE_MOCK_SERVICES=true

# PostgreSQL — create a local DB named orion_db
DATABASE_URL=postgresql://user:password@localhost:5432/orion_db

# Auth — change JWT_SECRET_KEY to a strong random string in production
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Logging
DEBUG=True
LOG_LEVEL=INFO

